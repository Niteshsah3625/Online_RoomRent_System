<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.roomrent.controller.ProfileController"
            prefWidth="700" prefHeight="580"
            styleClass="root-pane">

    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16" prefHeight="56">
            <Text text="🏠 Room Rent System" styleClass="navbar-brand"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="← Back to Dashboard" onAction="#handleBack" styleClass="btn-outline-sm"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane-flat">
            <VBox styleClass="form-panel" spacing="16" alignment="TOP_CENTER">

                <Label fx:id="pageTitleLabel" text="My Profile" styleClass="form-heading"/>
                <Label fx:id="roleLabel"      text=""           styleClass="text-muted"/>

                <GridPane hgap="16" vgap="12" maxWidth="500">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <Label text="Full Name *"  styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label text="Email"        styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="nameField"  promptText="Your full name" styleClass="text-field-custom"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="emailField" promptText="Email (read-only)" styleClass="text-field-custom"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Phone *"      styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="extraLabel"  text="Extra:" styleClass="field-label"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <TextField fx:id="phoneField" promptText="Phone number" styleClass="text-field-custom"
                               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="extraField" promptText="" styleClass="text-field-custom"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label fx:id="peopleLabel" text="No. of People:" styleClass="field-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Spinner fx:id="peopleSpinner" styleClass="spinner-custom"
                             GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                </GridPane>

                <Separator maxWidth="500"/>
                <Label text="Change Password (leave blank to keep current)"
                       styleClass="field-label" maxWidth="500"/>

                <GridPane hgap="16" vgap="10" maxWidth="500">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <Label text="New Password"    styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label text="Confirm Password" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <PasswordField fx:id="newPasswordField"     promptText="New password (min 6)" styleClass="text-field-custom"
                                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Repeat new password"  styleClass="text-field-custom"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>

                <Label fx:id="errorLabel"   styleClass="error-label"   wrapText="true" maxWidth="500"/>
                <Label fx:id="successLabel" styleClass="success-label" wrapText="true" maxWidth="500"/>

                <Button text="💾 Save Changes" onAction="#handleSave"
                        styleClass="btn-primary" prefHeight="42" maxWidth="500"/>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
