<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.roomrent.controller.OwnerDashboardController"
            prefWidth="1100" prefHeight="720"
            styleClass="root-pane">

    <!-- ── Top Navigation Bar ── -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="16" prefHeight="60">
            <Text text="🏠 Room Rent System" styleClass="navbar-brand"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" styleClass="navbar-welcome"/>
            <Button text="👤 Profile" onAction="#handleProfile" styleClass="btn-outline-sm"/>
            <Button text="⟳ Refresh" onAction="#handleRefresh" styleClass="btn-outline-sm"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger-sm"/>
        </HBox>
    </top>

    <!-- ── Main Content ── -->
    <center>
        <VBox spacing="18" style="-fx-padding: 20;">

            <!-- Stats Row -->
            <HBox spacing="16">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Text text="Total Rooms" styleClass="stat-label"/>
                    <Label fx:id="totalRoomsLabel" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Text text="Available" styleClass="stat-label"/>
                    <Label fx:id="availableRoomsLabel" text="0" styleClass="stat-value-green"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Text text="Pending Bookings" styleClass="stat-label"/>
                    <Label fx:id="pendingBookingsLabel" text="0" styleClass="stat-value-orange"/>
                </VBox>
            </HBox>

            <!-- My Rooms Section -->
            <VBox styleClass="card" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Text text="My Room Listings" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button text="+ Add Room"     onAction="#handleAddRoom"    styleClass="btn-primary-sm"/>
                    <Button text="✎ Edit"          onAction="#handleEditRoom"   styleClass="btn-outline-sm"/>
                    <Button text="🗑 Delete"        onAction="#handleDeleteRoom" styleClass="btn-danger-sm"/>
                </HBox>
                <TableView fx:id="roomTable" prefHeight="220" styleClass="table-view-custom">
                    <columns>
                        <TableColumn fx:id="colRoomId"   text="ID"       prefWidth="50"/>
                        <TableColumn fx:id="colTitle"    text="Title"    prefWidth="200"/>
                        <TableColumn fx:id="colLocation" text="Location" prefWidth="180"/>
                        <TableColumn fx:id="colPrice"    text="Price/Month" prefWidth="120"/>
                        <TableColumn fx:id="colRoomType" text="Type"     prefWidth="100"/>
                        <TableColumn fx:id="colStatus"   text="Status"   prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Booking Requests Section -->
            <VBox styleClass="card" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Text text="Booking Requests" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button text="✔ Confirm" onAction="#handleConfirmBooking" styleClass="btn-primary-sm"/>
                    <Button text="✘ Cancel"  onAction="#handleCancelBooking"  styleClass="btn-danger-sm"/>
                </HBox>
                <TableView fx:id="bookingTable" prefHeight="200" styleClass="table-view-custom">
                    <columns>
                        <TableColumn fx:id="colBookId"     text="ID"       prefWidth="50"/>
                        <TableColumn fx:id="colTenant"     text="Tenant"   prefWidth="160"/>
                        <TableColumn fx:id="colBookRoom"   text="Room"     prefWidth="180"/>
                        <TableColumn fx:id="colAmount"     text="Amount"   prefWidth="120"/>
                        <TableColumn fx:id="colDuration"   text="Duration" prefWidth="120"/>
                        <TableColumn fx:id="colBookStatus" text="Status"   prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>
</BorderPane>
